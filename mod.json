{
	"geode": "5.0.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"version": "v1.3.3",
	"id": "weebify.separate_dual_icons",
	"name": "Separate Dual Icons",
	"developer": "Weebify",
	"description": "Allows you to customize your 2nd player",
	"tags": [
		"gameplay",
		"interface",
		"customization"
	],
	"dependencies": {
		"geode.node-ids": ">=1.22.0"
	},
	"resources": {
		"sprites": [
			"./image.png",
			"res/*.png"
		]
	},
	"links": {
		"source": "https://github.com/Weebifying/separate-dual-icons-geode"
	},
	"settings": {
		"exitDualSwitch": {
			"type": "bool",
			"default": false,
			"name": "Exit Dual Switch",
			"description": "If player 2 exits the dual, player 1 switches to player 2's icon set"
		}
	}
